# .gitignore — Fincept Terminal (Qt6 / C++20)
# ============================================================

# ── CI config (local only) ──────────────────────────────────
.cirrus.yml

# ── CMake build output ───────────────────────────────────────
fincept-qt/build/
fincept-qt/build-*/
fincept-qt/build_*/
fincept-qt/tmpqt/
tmpqt/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
_deps/

# ── Compiled binaries & libraries ───────────────────────────
*.exe
*.dll
*.so
*.dylib
*.a
*.lib
*.pdb
*.ilk
*.exp
*.pyd

# ── Qt generated files ───────────────────────────────────────
*.moc
moc_*.cpp
moc_*.h
qrc_*.cpp
ui_*.h
*.qm

# ── Python artifacts ─────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.venv/
venv/
.pdm-python
.pdm-build

# ── IDE and editor ───────────────────────────────────────────
.idea/
.vscode/
*.suo
*.user
*.sln.docstates
*.ntvs*
*.njsproj
*.sw?
.DS_Store
Thumbs.db
agents.md

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/

# ── Database files (runtime, not source) ─────────────────────
*.db
*.db-shm
*.db-wal

# ── Environment & secrets — NEVER commit ─────────────────────
.env
.env.local
.env.*.local
*.key
*.pub

# ── Large data / ML model files ──────────────────────────────
*.csv
*.bin
*.pt
*.onnx
*.h5
*.pkl
*.pickle
*.model
*.weights

# ── Archives ─────────────────────────────────────────────────
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z

# ── Legacy (Tauri / React / Rust era — no longer in repo) ────
fincept-terminal-desktop/
fincept-cpp/
**/target/
*.rlib
*.rmeta
node_modules/
dist-ssr/

# ── Claude Code — never commit ───────────────────────────────
.claude/settings.local.json
CLAUDE.md
fincept-qt/DESIGN_SYSTEM.md

# ── Build output (uitest) ─────────────────────────────────────
fincept-qt/uitest/build/

# ── ML training artifacts ─────────────────────────────────────
lightning_logs/
*.ckpt
*.yaml

# ── Shell tree output files ───────────────────────────────────
**/tree

# ── Duplicate nested agents folder ───────────────────────────
fincept-qt/scripts/agents/agents/

# ── Firecrawl research artifacts ─────────────────────────────
.firecrawl/

# ── Exchange runtime cache ────────────────────────────────────
fincept-qt/scripts/exchange/.cache/

# ── Internal planning docs ────────────────────────────────────
fincept-qt/docs/superpowers/
